# Copy this file to .env.local and fill in your values

# Your deployed contract ID from: stellar contract deploy --alias minidonaa
# Example format: CAJ5GOACGHLLPYWOREVI4TSBSRJYUXSNBEIK26J2O5U6TJPDYGSRTIIQ
NEXT_PUBLIC_CONTRACT_ID=

# Network selection (testnet for development)
NEXT_PUBLIC_NETWORK=testnet
